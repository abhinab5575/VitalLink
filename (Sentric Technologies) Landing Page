<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sentric Technologies — Smarter Healthcare Connectivity</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --teal: #14B8A6;
    --teal-dim: #0d9488;
    --teal-glow: rgba(20,184,166,0.25);
    --navy: #0F172A;
    --navy-mid: #1E293B;
    --navy-light: #334155;
    --white: #FFFFFF;
    --gray-50: #F8FAFC;
    --gray-100: #F1F5F9;
    --gray-300: #CBD5E1;
    --gray-500: #64748B;
    --text-primary: #0F172A;
    --text-secondary: #475569;
    --radius-sm: 10px;
    --radius-md: 14px;
    --radius-lg: 20px;
    --radius-xl: 28px;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--white);
    color: var(--text-primary);
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }

  /* ========== NAV ========== */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 16px 24px;
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid rgba(20,184,166,0.1);
    transition: all 0.4s ease;
  }
  nav.scrolled {
    background: rgba(255,255,255,0.92);
    box-shadow: 0 4px 30px rgba(15,23,42,0.08);
  }
  .nav-logo {
    display: flex; align-items: center; gap: 10px;
    font-size: 18px; font-weight: 600; color: var(--navy);
    text-decoration: none;
  }
  .nav-logo-icon {
    width: 34px; height: 34px;
    background: linear-gradient(135deg, var(--teal), #0891b2);
    border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 12px var(--teal-glow);
  }
  .nav-logo-icon svg { width: 18px; height: 18px; color: white; }
  .nav-links {
    display: none; gap: 32px; list-style: none;
  }
  @media(min-width:768px){ .nav-links { display: flex; } }
  .nav-links a {
    font-size: 14px; font-weight: 500; color: var(--text-secondary);
    text-decoration: none; transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--teal); }
  .nav-cta {
    background: var(--navy);
    color: white; border: none;
    padding: 10px 22px; border-radius: 50px;
    font-size: 14px; font-weight: 500;
    cursor: pointer; transition: all 0.3s ease;
    font-family: inherit;
  }
  .nav-cta:hover {
    background: var(--teal);
    box-shadow: 0 6px 20px var(--teal-glow);
    transform: translateY(-1px);
  }

  /* ========== HERO ========== */
  .hero {
    min-height: 100vh;
    background: var(--navy);
    position: relative;
    display: flex; align-items: center;
    overflow: hidden;
    padding: 120px 24px 80px;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 60% 0%, rgba(20,184,166,0.18) 0%, transparent 60%),
      radial-gradient(ellipse 60% 80% at 0% 100%, rgba(8,145,178,0.12) 0%, transparent 60%);
  }
  .hero-grid {
    position: absolute; inset: 0; opacity: 0.04;
    background-image:
      linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px);
    background-size: 50px 50px;
  }
  /* floating orbs */
  .orb {
    position: absolute; border-radius: 50%;
    filter: blur(60px); pointer-events: none;
  }
  .orb-1 {
    width: 400px; height: 400px;
    background: rgba(20,184,166,0.15);
    top: -100px; right: -100px;
    animation: floatOrb 8s ease-in-out infinite;
  }
  .orb-2 {
    width: 250px; height: 250px;
    background: rgba(8,145,178,0.12);
    bottom: 100px; left: -80px;
    animation: floatOrb 10s ease-in-out infinite reverse;
  }
  @keyframes floatOrb {
    0%,100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-30px) scale(1.05); }
  }

  .hero-inner {
    position: relative; z-index: 2;
    max-width: 1200px; margin: 0 auto; width: 100%;
    display: grid; grid-template-columns: 1fr;
    gap: 60px; align-items: center;
  }
  @media(min-width:900px){ .hero-inner { grid-template-columns: 1fr 1fr; } }

  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(20,184,166,0.12);
    border: 1px solid rgba(20,184,166,0.3);
    border-radius: 50px;
    padding: 6px 14px;
    font-size: 12px; font-weight: 500; color: var(--teal);
    margin-bottom: 24px;
    animation: fadeUp 0.8s ease both;
  }
  .badge-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--teal);
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%,100%{ box-shadow: 0 0 0 0 rgba(20,184,166,0.6); }
    50%{ box-shadow: 0 0 0 4px rgba(20,184,166,0); }
  }

  .hero-title {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(38px, 7vw, 68px);
    line-height: 1.08;
    color: var(--white);
    margin-bottom: 20px;
    animation: fadeUp 0.8s 0.1s ease both;
  }
  .hero-title em {
    font-style: italic;
    background: linear-gradient(120deg, var(--teal), #7dd3fc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-sub {
    font-size: 17px; line-height: 1.7;
    color: rgba(255,255,255,0.6);
    max-width: 480px;
    margin-bottom: 36px;
    animation: fadeUp 0.8s 0.2s ease both;
  }
  .hero-actions {
    display: flex; flex-wrap: wrap; gap: 14px; align-items: center;
    animation: fadeUp 0.8s 0.3s ease both;
  }
  .btn-primary {
    background: var(--teal);
    color: white;
    padding: 14px 30px; border-radius: 50px;
    font-size: 15px; font-weight: 500;
    border: none; cursor: pointer;
    font-family: inherit;
    position: relative; overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 8px 30px var(--teal-glow);
  }
  .btn-primary::after {
    content: '';
    position: absolute; inset: 0;
    background: rgba(255,255,255,0);
    transition: background 0.3s;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 40px rgba(20,184,166,0.5);
  }
  .btn-primary:active { transform: translateY(0); }
  .btn-ghost {
    background: transparent;
    color: rgba(255,255,255,0.7);
    padding: 14px 24px; border-radius: 50px;
    font-size: 15px; font-weight: 400;
    border: 1px solid rgba(255,255,255,0.15);
    cursor: pointer; font-family: inherit;
    display: flex; align-items: center; gap: 8px;
    transition: all 0.3s ease;
  }
  .btn-ghost:hover {
    border-color: var(--teal);
    color: var(--teal);
  }
  .play-icon {
    width: 24px; height: 24px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }

  /* Hero visual */
  .hero-visual {
    position: relative;
    display: flex; justify-content: center;
    animation: fadeUp 0.8s 0.4s ease both;
  }
  .hero-card-main {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(20px);
    border-radius: var(--radius-xl);
    padding: 28px;
    width: 100%; max-width: 420px;
    position: relative;
  }
  .vitals-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 24px;
  }
  .vitals-title { font-size: 13px; color: rgba(255,255,255,0.5); font-weight: 400; }
  .vitals-live {
    display: flex; align-items: center; gap: 6px;
    font-size: 11px; color: var(--teal); font-weight: 500;
  }
  .live-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--teal);
    animation: pulse-dot 1.5s ease-in-out infinite;
  }
  .vitals-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 14px; margin-bottom: 20px;
  }
  .vital-chip {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-md);
    padding: 14px;
  }
  .vital-label { font-size: 11px; color: rgba(255,255,255,0.4); margin-bottom: 6px; }
  .vital-value { font-size: 22px; font-weight: 600; color: white; }
  .vital-value span { font-size: 11px; font-weight: 400; color: rgba(255,255,255,0.4); }
  .vital-value.ok { color: var(--teal); }
  /* heartbeat svg */
  .ecg-line {
    stroke-dasharray: 400;
    stroke-dashoffset: 400;
    animation: ecgDraw 2s ease forwards, ecgLoop 3s 2s linear infinite;
  }
  @keyframes ecgDraw { to { stroke-dashoffset: 0; } }
  @keyframes ecgLoop { 0%{ stroke-dashoffset: 0; } 100%{ stroke-dashoffset: -400; } }

  /* floating mini-cards */
  .float-card {
    position: absolute;
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius-md);
    padding: 12px 16px;
    font-size: 12px; color: white;
    white-space: nowrap;
  }
  .float-card-1 {
    top: -24px; right: -16px;
    animation: floatCard 4s ease-in-out infinite;
  }
  .float-card-2 {
    bottom: -20px; left: -20px;
    animation: floatCard 5s 1s ease-in-out infinite reverse;
  }
  @keyframes floatCard {
    0%,100%{ transform: translateY(0); }
    50%{ transform: translateY(-10px); }
  }
  .float-icon { display: inline-block; margin-right: 6px; }
  .float-card .fc-title { color: rgba(255,255,255,0.5); font-size: 10px; }
  .float-card .fc-val { font-weight: 600; font-size: 14px; color: var(--teal); }

  /* hero stats strip */
  .hero-stats {
    display: flex; gap: 32px; flex-wrap: wrap;
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid rgba(255,255,255,0.08);
    animation: fadeUp 0.8s 0.5s ease both;
  }
  .hstat-val {
    font-size: 26px; font-weight: 600; color: white;
    margin-bottom: 4px;
  }
  .hstat-label { font-size: 13px; color: rgba(255,255,255,0.4); }

  /* ========== SECTION WRAPPER ========== */
  section { padding: 100px 24px; }
  .container { max-width: 1200px; margin: 0 auto; }
  .section-tag {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 12px; font-weight: 600; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--teal);
    margin-bottom: 16px;
  }
  .section-tag::before {
    content:''; display:block; width:20px; height:2px;
    background: var(--teal); border-radius: 2px;
  }
  .section-title {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(30px, 4vw, 48px);
    line-height: 1.15;
    color: var(--text-primary);
    margin-bottom: 16px;
  }
  .section-sub {
    font-size: 17px; line-height: 1.7;
    color: var(--text-secondary);
    max-width: 560px;
  }

  /* ========== FEATURES ========== */
  .features { background: var(--gray-50); }
  .features-header { text-align: center; margin-bottom: 56px; }
  .features-header .section-tag { justify-content: center; }
  .features-header .section-tag::before { display: none; }
  .features-header .section-sub { margin: 0 auto; }
  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media(min-width:640px){ .features-grid { grid-template-columns: 1fr 1fr; } }
  @media(min-width:1024px){ .features-grid { grid-template-columns: repeat(3,1fr); } }

  .feat-card {
    background: white;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: var(--radius-lg);
    padding: 28px 24px;
    transition: all 0.4s cubic-bezier(0.23,1,0.32,1);
    cursor: default;
    position: relative; overflow: hidden;
  }
  .feat-card::before {
    content:'';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(20,184,166,0.04), transparent);
    opacity: 0; transition: opacity 0.4s;
  }
  .feat-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 60px rgba(20,184,166,0.12), 0 4px 16px rgba(0,0,0,0.06);
    border-color: rgba(20,184,166,0.2);
  }
  .feat-card:hover::before { opacity: 1; }
  .feat-icon {
    width: 52px; height: 52px;
    border-radius: var(--radius-md);
    background: rgba(20,184,166,0.1);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 20px;
    transition: all 0.3s;
  }
  .feat-card:hover .feat-icon {
    background: var(--teal);
    box-shadow: 0 8px 24px var(--teal-glow);
  }
  .feat-card:hover .feat-icon svg { color: white; }
  .feat-icon svg { width: 24px; height: 24px; color: var(--teal); transition: color 0.3s; }
  .feat-title { font-size: 17px; font-weight: 600; color: var(--navy); margin-bottom: 10px; }
  .feat-desc { font-size: 14px; line-height: 1.65; color: var(--text-secondary); }

  /* ========== INTEGRATION SECTION ========== */
  .integration { background: white; }
  .integration-inner {
    display: grid; grid-template-columns: 1fr;
    gap: 60px; align-items: center;
  }
  @media(min-width:900px){ .integration-inner { grid-template-columns: 1fr 1fr; } }

  .int-visual {
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--navy);
    padding: 32px;
    position: relative;
  }
  .int-visual-bg {
    position: absolute; inset:0;
    background: radial-gradient(ellipse at 70% 30%, rgba(20,184,166,0.15), transparent 60%);
  }
  .network-diagram {
    position: relative; height: 280px; z-index:1;
    display: flex; align-items: center; justify-content: center;
  }
  .node {
    position: absolute;
    display: flex; flex-direction: column; align-items: center; gap: 6px;
  }
  .node-circle {
    width: 52px; height: 52px;
    border-radius: 50%;
    border: 2px solid rgba(20,184,166,0.4);
    background: rgba(20,184,166,0.1);
    display: flex; align-items: center; justify-content: center;
    transition: all 0.3s;
    animation: nodePulse 3s ease-in-out infinite;
  }
  .node-circle svg { width: 22px; height: 22px; color: var(--teal); }
  .node-label { font-size: 11px; color: rgba(255,255,255,0.6); font-weight: 500; }
  .node-center { top: 50%; left: 50%; transform: translate(-50%,-50%); }
  .node-center .node-circle {
    width: 70px; height: 70px;
    background: rgba(20,184,166,0.2);
    border-color: var(--teal);
    box-shadow: 0 0 40px var(--teal-glow);
    animation: centerPulse 2.5s ease-in-out infinite;
  }
  .node-center .node-circle svg { width: 30px; height: 30px; }
  .node-top { top: 10%; left: 50%; transform: translateX(-50%); animation-delay: 0.5s; }
  .node-right { top: 50%; right: 5%; transform: translateY(-50%); animation-delay: 1s; }
  .node-bottom { bottom: 10%; left: 50%; transform: translateX(-50%); animation-delay: 1.5s; }
  .node-left { top: 50%; left: 5%; transform: translateY(-50%); animation-delay: 2s; }
  @keyframes nodePulse {
    0%,100%{ box-shadow: 0 0 0 0 rgba(20,184,166,0.3); }
    50%{ box-shadow: 0 0 0 8px rgba(20,184,166,0); }
  }
  @keyframes centerPulse {
    0%,100%{ box-shadow: 0 0 20px var(--teal-glow), 0 0 0 0 rgba(20,184,166,0.4); }
    50%{ box-shadow: 0 0 40px var(--teal-glow), 0 0 0 16px rgba(20,184,166,0); }
  }
  /* connection lines */
  .connections {
    position: absolute; inset: 0; pointer-events: none;
  }
  .conn-line {
    stroke: rgba(20,184,166,0.25);
    stroke-dasharray: 4 4;
    animation: dashMove 2s linear infinite;
  }
  @keyframes dashMove { to { stroke-dashoffset: -16; } }

  .int-text .section-title { margin-top: 0; }
  .int-list { list-style: none; margin-top: 28px; display: flex; flex-direction: column; gap: 16px; }
  .int-list li {
    display: flex; align-items: flex-start; gap: 14px;
    font-size: 15px; line-height: 1.6; color: var(--text-secondary);
  }
  .int-check {
    width: 24px; height: 24px; flex-shrink: 0;
    background: rgba(20,184,166,0.1);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin-top: 2px;
  }
  .int-check svg { width: 13px; height: 13px; color: var(--teal); }

  /* ========== BENEFITS ========== */
  .benefits { background: var(--gray-50); }
  .benefits-header { text-align: center; margin-bottom: 48px; }
  .benefits-header .section-tag { justify-content: center; }
  .benefits-header .section-tag::before { display: none; }
  .benefits-header .section-sub { margin: 0 auto; }

  .benefits-grid {
    display: grid; grid-template-columns: 1fr;
    gap: 16px;
  }
  @media(min-width:768px){ .benefits-grid { grid-template-columns: repeat(3,1fr); } }

  .ben-card {
    background: linear-gradient(135deg, var(--teal) 0%, #0891b2 100%);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    color: white;
    position: relative; overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.23,1,0.32,1), box-shadow 0.4s;
  }
  .ben-card::before {
    content:'';
    position: absolute; top:-30px; right:-30px;
    width:120px; height:120px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
  }
  .ben-card::after {
    content:'';
    position: absolute; bottom:-40px; left:-20px;
    width:100px; height:100px;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
  }
  .ben-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 50px rgba(20,184,166,0.35);
  }
  .ben-icon {
    width: 48px; height: 48px;
    background: rgba(255,255,255,0.2);
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 20px;
  }
  .ben-icon svg { width: 22px; height: 22px; color: white; }
  .ben-title { font-size: 19px; font-weight: 600; margin-bottom: 10px; }
  .ben-desc { font-size: 14px; line-height: 1.65; opacity: 0.8; }

  /* ========== USE CASES ========== */
  .usecases { background: white; }
  .usecases-header { text-align: center; margin-bottom: 48px; }
  .usecases-header .section-tag { justify-content: center; }
  .usecases-header .section-tag::before { display: none; }
  .tags-wrap {
    display: flex; flex-wrap: wrap; gap: 14px;
    justify-content: center;
    margin-bottom: 56px;
  }
  .uc-tag {
    padding: 12px 24px;
    border-radius: 50px;
    border: 1.5px solid var(--gray-300);
    font-size: 14px; font-weight: 500; color: var(--text-secondary);
    cursor: pointer; transition: all 0.3s ease;
    background: white;
  }
  .uc-tag:hover, .uc-tag.active {
    border-color: var(--teal);
    color: var(--teal);
    background: rgba(20,184,166,0.06);
    transform: scale(1.04);
    box-shadow: 0 4px 16px var(--teal-glow);
  }

  /* Use case detail */
  .uc-detail-grid {
    display: grid; grid-template-columns: 1fr;
    gap: 32px;
  }
  @media(min-width:768px){ .uc-detail-grid { grid-template-columns: 1fr 1fr 1fr; } }

  .uc-detail-card {
    border: 1px solid var(--gray-100);
    border-radius: var(--radius-lg);
    padding: 28px;
    transition: all 0.3s;
  }
  .uc-detail-card:hover {
    border-color: rgba(20,184,166,0.2);
    box-shadow: 0 8px 30px rgba(20,184,166,0.08);
  }
  .uc-num { font-size: 40px; font-weight: 700; color: rgba(20,184,166,0.15); line-height: 1; margin-bottom: 12px; }
  .uc-title { font-size: 17px; font-weight: 600; color: var(--navy); margin-bottom: 10px; }
  .uc-desc { font-size: 14px; line-height: 1.65; color: var(--text-secondary); }

  /* ========== STATS ========== */
  .stats { background: var(--navy); padding: 80px 24px; }
  .stats-inner { max-width: 1200px; margin: 0 auto; }
  .stats-title {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(26px, 3vw, 40px);
    color: white; text-align: center;
    margin-bottom: 56px;
  }
  .stats-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  @media(min-width:768px){ .stats-grid { grid-template-columns: repeat(4,1fr); } }

  .stat-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-lg);
    padding: 28px 20px;
    text-align: center;
    transition: all 0.3s;
  }
  .stat-card:hover {
    background: rgba(20,184,166,0.08);
    border-color: rgba(20,184,166,0.25);
